@page
@model IndexModel
@{
    ViewData["Title"] = "Secure File Upload Portal";
}

<div class="portal-container">
    <div class="portal-card">
        <div class="portal-header">
            <div class="lock-icon">🔐</div>
            <h1>Secure File Upload Portal</h1>
            <p class="subtitle">Enter your email to receive a one-time password</p>
        </div>

        @if (Model.ErrorMessage is not null)
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post">
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email"
                       id="email"
                       name="email"
                       class="form-control"
                       placeholder="you@company.com"
                       required
                       autocomplete="email" />
            </div>
            <button type="submit" class="btn-primary">
                Send OTP
            </button>
        </form>

        <div class="info-box">
            <p>💡 A 6-digit one-time password will be sent to your email address. The code expires in 10 minutes.</p>
        </div>
    </div>
</div>
